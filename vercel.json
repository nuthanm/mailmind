{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/auth/:path*",              "destination": "/api/auth" },
    { "source": "/api/settings",                 "destination": "/api/settings" },
    { "source": "/api/realtime/:path*",          "destination": "/api/realtime" },
    { "source": "/api/gmail/accounts",           "destination": "/api/gmail" },
    { "source": "/api/gmail/connect",            "destination": "/api/gmail" },
    { "source": "/api/gmail/callback",           "destination": "/api/gmail" },
    { "source": "/api/gmail/fetch",              "destination": "/api/gmail" },
    { "source": "/api/gmail/quota",              "destination": "/api/gmail" },
    { "source": "/api/gmail/disconnect/:id",     "destination": "/api/gmail" },
    { "source": "/api/unsubscribe/scan",         "destination": "/api/unsubscribe" },
    { "source": "/api/unsubscribe/queue",        "destination": "/api/unsubscribe" },
    { "source": "/api/unsubscribe/fire",         "destination": "/api/unsubscribe" },
    { "source": "/api/unsubscribe/fire-all",     "destination": "/api/unsubscribe" },
    { "source": "/api/unsubscribe/block",        "destination": "/api/unsubscribe" },
    { "source": "/api/unsubscribe/:id",          "destination": "/api/unsubscribe" },
    { "source": "/api/unsubscribe",              "destination": "/api/unsubscribe" },
    { "source": "/api/(.*)",                     "destination": "/api/$1" },
    { "source": "/(.*)",                         "destination": "/index.html" }
  ],
  "env": {
    "DATABASE_URL":           "@database_url",
    "SESSION_SECRET":         "@session_secret",
    "JWT_SECRET":             "@jwt_secret",
    "GOOGLE_CLIENT_ID":       "@google_client_id",
    "GOOGLE_CLIENT_SECRET":   "@google_client_secret",
    "GOOGLE_REDIRECT_URI":    "@google_redirect_uri",
    "APP_URL":                "@app_url"
  }
}
