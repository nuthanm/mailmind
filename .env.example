# Neon PostgreSQL connection string
# Get from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/mailmind?sslmode=require

# Session secret - generate with: openssl rand -hex 32
SESSION_SECRET=your_random_secret_here_at_least_32_chars

# JWT secret for auth tokens - generate: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# Google OAuth credentials
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: gmail.readonly, gmail.modify (for unsubscribe)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match exactly what you put in Google Console → Authorized redirect URIs
# Local dev: http://localhost:3001/api/gmail/callback
# Production: https://your-app.vercel.app/api/gmail/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# Optional: Default AI provider (user can override per-session)
# Options: openai | anthropic
DEFAULT_AI_PROVIDER=openai

# App URL (used for CORS in production)
APP_URL=https://your-app.vercel.app
